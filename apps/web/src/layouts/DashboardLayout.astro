---
import BaseLayout from './BaseLayout.astro';
import DashboardProviders from '../components/DashboardProviders';
import MessageAlerts from '../components/MessageAlerts';
const { title } = Astro.props;
---

<BaseLayout title={title || 'Dashboard — WAGO'}>
  <DashboardProviders client:load>
    <div class="flex min-h-screen">
      <aside class="hidden w-64 border-r border-border-primary bg-bg-secondary p-4 lg:block">
        <a href="/dashboard/connections" class="mb-6 flex items-center gap-2">
          <img src="/logo.svg" alt="" class="h-7 w-7" />
          <span class="text-lg font-bold"><span class="text-wa-green">WA</span><span class="text-white">GO</span></span>
        </a>
        <nav class="space-y-1" id="sidebar-nav">
          <a href="/dashboard/connections" class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium text-text-secondary hover:bg-bg-elevated hover:text-text-primary transition-colors sidebar-link">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
            Connections
          </a>
          <a href="/dashboard/tokens" class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium text-text-secondary hover:bg-bg-elevated hover:text-text-primary transition-colors sidebar-link">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" /></svg>
            API Tokens
          </a>
        </nav>
        <div class="mt-auto pt-4 border-t border-border-primary">
          <button onclick="window.location.href='/login'" class="flex w-full items-center gap-3 rounded-lg px-3 py-2 text-sm text-text-tertiary hover:text-text-primary transition-colors">
            Sign out
          </button>
        </div>
      </aside>
      <main class="flex-1 p-6 lg:p-8">
        <slot />
      </main>
    </div>
    <MessageAlerts client:load />
  </DashboardProviders>
</BaseLayout>
