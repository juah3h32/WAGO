---
import BaseLayout from './BaseLayout.astro';
import DashboardProviders from '../components/DashboardProviders';
import MessageAlerts from '../components/MessageAlerts';
const { title } = Astro.props;
---

<BaseLayout title={title || 'Dashboard — WAGO'}>
  <DashboardProviders client:load>
    <div class="flex min-h-screen">

      <!-- Sidebar -->
      <aside class="hidden lg:flex w-[72px] xl:w-60 shrink-0 flex-col border-r border-border-primary bg-bg-secondary">

        <!-- Logo -->
        <a href="/dashboard/connections" class="flex items-center gap-3 px-4 py-5 border-b border-border-primary hover:bg-bg-elevated transition-colors">
          <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-wa-green">
            <svg class="h-5 w-5 text-text-inverse" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <span class="hidden xl:block text-base font-bold"><span class="text-wa-green">WA</span><span class="text-text-primary">GO</span></span>
        </a>

        <!-- Nav -->
        <nav class="flex-1 px-2 py-4 space-y-1">
          <a href="/dashboard/connections" id="nav-connections"
            class="sidebar-link flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium text-text-secondary hover:bg-bg-elevated hover:text-text-primary transition-all">
            <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
            <span class="hidden xl:block">Conexiones</span>
          </a>
          <a href="/dashboard/tokens" id="nav-tokens"
            class="sidebar-link flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium text-text-secondary hover:bg-bg-elevated hover:text-text-primary transition-all">
            <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
            </svg>
            <span class="hidden xl:block">API Tokens</span>
          </a>
        </nav>

        <!-- Footer -->
        <div class="border-t border-border-primary px-2 py-3">
          <a href="/login"
            class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm text-text-tertiary hover:bg-bg-elevated hover:text-text-secondary transition-all">
            <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            <span class="hidden xl:block">Cerrar sesión</span>
          </a>
        </div>
      </aside>

      <!-- Main content -->
      <main class="flex-1 min-w-0 overflow-auto">
        <div class="mx-auto max-w-5xl px-4 py-6 lg:px-8 lg:py-8">
          <slot />
        </div>
      </main>
    </div>

    <MessageAlerts client:load />
  </DashboardProviders>
</BaseLayout>

<script>
  // Highlight active sidebar link
  const path = window.location.pathname;
  document.querySelectorAll('.sidebar-link').forEach((el) => {
    const href = el.getAttribute('href') || '';
    if (path === href || path.startsWith(href + '/')) {
      el.classList.add('bg-wa-green-light', 'text-wa-green');
      el.classList.remove('text-text-secondary');
    }
  });
</script>
