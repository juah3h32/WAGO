---
import { ToastProvider } from '../components/toast';
const { title } = Astro.props;
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY ?? '';
const apiUrl = import.meta.env.PUBLIC_API_URL ?? '';
---

<html lang="es" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta id="app-config"
      data-supabase-url={supabaseUrl}
      data-supabase-key={supabaseKey}
      data-api-url={apiUrl} />
    <script is:inline>
      const _cfg = document.getElementById('app-config');
      window.__SUPABASE_URL__ = _cfg?.dataset?.supabaseUrl ?? '';
      window.__SUPABASE_KEY__ = _cfg?.dataset?.supabaseKey ?? '';
      window.__API_URL__ = _cfg?.dataset?.apiUrl ?? '';
    </script>
  </head>
  <body>
    <ToastProvider client:load>
      <slot />
    </ToastProvider>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
